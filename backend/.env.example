# Shuggi Backend - Environment Variables Template
# Copia este archivo a .env y completa con tus valores

# ============================================
# App Configuration
# ============================================
PORT=3000
NODE_ENV=development

# ============================================
# Database
# ============================================
MONGO_URI=mongodb://127.0.0.1:27017/shuggi

# ============================================
# JWT & Security
# ============================================
JWT_SECRET=tu-secreto-muy-seguro-aqui-cambiar-en-produccion

# ============================================
# Pack Configuration
# ============================================
MIN_DISCOUNT_PERCENTAGE=40
MAX_DISCOUNT_PERCENTAGE=80
PLATFORM_COMMISSION_RATE=0.10
MAX_ADVANCE_DAYS=7
MAX_ACTIVE_PACKS=14
MAX_PACKS_PER_DAY=2

# ============================================
# Payment Gateway - PayU Colombia
# ============================================
PAYMENT_GATEWAY=payu
PAYMENT_GATEWAY_PERCENTAGE_FEE=0.0392
PAYMENT_GATEWAY_FIXED_FEE=300
MINIMUM_TRANSACTION_AMOUNT=10000

# ============================================
# Order Configuration
# ============================================
PAYMENT_TIMEOUT_MINUTES=15
FREE_CANCELLATION_HOURS=24

# ============================================
# PayU Credentials (SANDBOX EXAMPLE)
# Cambiar con credenciales reales en producción
# ============================================
PAYU_MERCHANT_ID=508029
PAYU_ACCOUNT_ID=512321
PAYU_API_KEY=tu-api-key-aqui
PAYU_API_LOGIN=tu-api-login-aqui
PAYU_PUBLIC_KEY=tu-public-key-aqui
PAYU_TEST_MODE=true

# ============================================
# PayU URLs
# ============================================
PAYU_PAYMENT_URL=https://sandbox.checkout.payulatam.com/ppp-web-gateway-payu/
PAYU_CONFIRMATION_URL=http://localhost:3000/payments/webhook
PAYU_RESPONSE_URL=http://localhost:4200/orders/payment-result

# ============================================
# CORS - Allowed Origins
# ============================================
ALLOWED_ORIGINS=http://localhost:4200,http://localhost:3001,http://localhost:8080

# ============================================
# Email Configuration (Gmail example)
# Usar App Password en lugar de contraseña real
# ============================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=tu-email@gmail.com
MAIL_PASSWORD=tu-app-password-aqui
MAIL_FROM=noreply@shuggi.com

# ============================================
# Frontend URL (para enlaces en emails)
# ============================================
FRONTEND_URL=http://localhost:4200
